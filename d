graph TD
 af(EDO Starts)
 af --Triggers--> nifi(NiFi) 
 af --Triggers--> dep
 af --Triggers--> precheck(Pre Checks Pipeline)
 nifi--Transfer---> hdfs  
 hdfs -.-> nm(Menifest)

 subgraph hdfs [HDFS]
  ctrlf(Control Files)
  gf(Glif Files)
  cf(CBS Files)
 end



 subgraph dep [Data ETL Pipelines]
    lgd(Glif Data Loads)
    lcd(CBS Data Loading)
 end

 subgraph dtlp [Data Processing Pipelines]
    gp
    cp
 end
 gf-->lgd
 cf-->lcd
 lgd-.->gm(Menifest)
 lcd-.->cm(Menifest)
 gm-->gp(Glif Pipeline)
 cm-->cp(CBS Pipeline)
 gp-.->ddm(Menifest)
 cp-.->dcm(Menifest)

ddm-->intr & cntr
 precheck-.->pm(Menifest)
subgraph check [Check]
i(If all 3 present)
end
 pm-->check
 dcm -->check
 ddm -->check
 check-->glcc

 subgraph dfp [Difference Pipeline]
 glcc(Balance Compare)
 intr(INTR Report)
 cntr(CNTR Report)
 end
 dfp-.->dfm(Menifest)
 dfm --Triggers--->rg(Report Generation)
 dfm --Triggers---> etlp(ETL + 1)

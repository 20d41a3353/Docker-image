<!-- Put site-specific property overrides in this file. -->

<configuration>
    <!-- Replication factor for single-node setup -->
    <property>
        <name>dfs.replication</name>
        <value>1</value>
    </property>

    <!-- NameNode Data Storage Location -->
    <property>
        <name>dfs.namenode.name.dir</name>
        <value>file:///D:/Softwares/BigData/hadoop/hadoop-3.5.0/data/namenode</value>
    </property>

    <!-- DataNode Data Storage Location -->
    <property>
        <name>dfs.datanode.data.dir</name>
        <value>file:///D:/Softwares/BigData/hadoop/hadoop-3.5.0/data/datanode</value>
    </property>

    <!-- Set explicit local IP for NameNode web UI and IPC connection -->
    <property>
        <name>dfs.namenode.rpc-address</name>
        <value>10.0.17.76:8020</value>
    </property>
    <property>
        <name>dfs.namenode.http-address</name>
        <value>10.0.17.76:9870</value>
    </property>
    <property>
	<name>dfs.datanode.hostname</name>
	<value>10.0.17.76</value>
    </property>
    <property>
    <name>dfs.permissions.enabled</name>
    <value>false</value>
</property>

<!--dfs.webhdfs.enabled to download files from ui -->

<property>
  <name>dfs.webhdfs.enabled</name>
  <value>true</value>
</property>

</configuration>

